# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Server
PORT=3000
NODE_ENV=development

# JWT — must be a strong, randomly generated secret (min 32 characters)
JWT_SECRET="your-strong-secret-key-change-in-production"
